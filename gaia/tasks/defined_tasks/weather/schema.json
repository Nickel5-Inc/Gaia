{
    "forecast_runs": {
        "table_name": "forecast_runs",
        "database_type": "validator",
        "columns": {
            "id": "SERIAL PRIMARY KEY",
            "start_time": "TIMESTAMP WITH TIME ZONE NOT NULL",
            "end_time": "TIMESTAMP WITH TIME ZONE",
            "input_data_hash": "TEXT NOT NULL",
            "status": "TEXT NOT NULL DEFAULT 'in_progress'",
            "notes": "TEXT",
            "created_at": "TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP"
        },
        "indexes": [
            {"column": "start_time", "unique": false},
            {"column": "status", "unique": false}
        ]
    },
    "miner_forecasts": {
        "table_name": "miner_forecasts",
        "database_type": "validator",
        "columns": {
            "id": "SERIAL PRIMARY KEY",
            "run_id": "INTEGER REFERENCES forecast_runs(id)",
            "miner_uid": "TEXT NOT NULL",
            "miner_hotkey": "TEXT NOT NULL",
            "forecast_subset_path": "TEXT NOT NULL",
            "forecast_hash": "TEXT NOT NULL",
            "submission_time": "TIMESTAMP WITH TIME ZONE NOT NULL",
            "metadata": "JSONB",
            "retention_expires": "TIMESTAMP WITH TIME ZONE",
            "created_at": "TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP",
            "status": "TEXT NOT NULL DEFAULT 'active'"
        },
        "indexes": [
            {"column": "run_id", "unique": false},
            {"column": "miner_hotkey", "unique": false},
            {"column": "submission_time", "unique": false},
            {"column": "status", "unique": false}
        ],
        "foreign_keys": [
            {
                "column": "run_id",
                "references": "forecast_runs(id)",
                "on_delete": "CASCADE"
            }
        ]
    },
